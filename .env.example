# Vibe Monitor Environment Variables
# Copy this file to .env.local and fill in the values

# WebSocket server URL (use ws:// or wss://)
# Default: wss://ws.vibemon.io
# VIBEMON_WS_URL="wss://ws.vibemon.io"

# Authentication token for WebSocket server (optional)
# Can also be set via Settings > Collector > Token
# Once set in Settings, the stored value takes precedence
# VIBEMON_WS_TOKEN=

# Hook installer docs base URL (advanced; custom installer deployments)
# Default: https://docs.vibemon.io
# VIBEMON_DOCS_URL="https://docs.vibemon.io"

# SHA-256 the downloaded install.py is verified against before it runs
# (advanced; must match the installer served by VIBEMON_DOCS_URL)
# VIBEMON_INSTALLER_SHA256=
